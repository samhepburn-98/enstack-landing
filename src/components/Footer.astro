---
import { navLinks } from "@/data/navLinks";

const year = new Date().getFullYear();
---

<footer class="relative px-6 md:px-16 lg:px-24 xl:px-32 mt-40 w-full dark:text-slate-50">
  <img
    src="/assets/landing-text-light.svg"
    alt="landing"
    class="absolute max-w-4xl w-full h-auto -mt-30 max-md:px-4 right-0 md:right-16 lg:right-24 xl:right-32 top-0 pointer-events-none block dark:hidden"
  />
  <img
    src="/assets/landing-text-dark.svg"
    alt="landing"
    class="absolute max-w-4xl w-full h-auto -mt-30 max-md:px-4 right-0 md:right-16 lg:right-24 xl:right-32 top-0 pointer-events-none hidden dark:block"
  />
  <div class="flex flex-col md:flex-row justify-between w-full gap-10 border-b border-gray-200 dark:border-slate-700 pb-6">
    <div class="md:max-w-114">
      <a href="/">
        <img src="/assets/logo-dark.svg" alt="Logo" class="h-9 md:h-9.5 w-auto shrink-0 block dark:hidden" />
        <img src="/assets/logo-light.svg" alt="Logo" class="h-9 md:h-9.5 w-auto shrink-0 hidden dark:block" />
      </a>
      <p class="mt-6">
        We build our own digital products and help other businesses do the same — apps, websites, and brand design.
      </p>
    </div>
    <div class="flex-1 flex items-start md:justify-end gap-20">
      <div>
        <h2 class="font-semibold mb-5">Company</h2>
        <ul class="space-y-2">
          {navLinks.map((link) => (
            <li>
              <a href={link.href} class="hover:text-[#00DCC2] transition">{link.name}</a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h2 class="font-semibold mb-5">Get in touch</h2>
        <div class="space-y-2">
          <p>hello@enstack.co.uk</p>
        </div>
      </div>
    </div>
  </div>
  <p class="pt-4 text-center pb-5">
    Copyright {year} © <a href="/">EnStack Ltd</a>. All Rights Reserved.
  </p>
</footer>

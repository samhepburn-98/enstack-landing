---
interface Props {
  text1: string;
  text2: string;
  text3: string;
}

const { text1, text2, text3 } = Astro.props;
---

<p class="text-center font-medium text-[#00DCC2] mt-28 px-10 py-2 rounded-full bg-slate-50 dark:bg-[#042B31] border border-slate-300 dark:border-[#00DCC2]/20 w-max mx-auto">
  {text1}
</p>
<h3 class="text-3xl font-semibold text-center mx-auto mt-4">{text2}</h3>
<p class="text-slate-600 dark:text-slate-300 text-center mt-2 max-w-lg mx-auto">{text3}</p>
